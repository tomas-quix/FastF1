# Quix SDK Token - find this in the Quix Portal under Settings > Tokens (SDK Tokens section)
Quix__Sdk__Token=

# Topic names (from your Quix environment)
input_car_data=openf1-car-data
input_config=config-ui
input_laps=openf1-laps

# QuixLake settings
TABLE_NAME=car_telemetry
S3_PREFIX=data-lake/time-series

# Kafka consumer group
CONSUMER_GROUP=openf1-car-data-lake-sink-v1
