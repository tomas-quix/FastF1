# Quix SDK token — find in Settings > Tokens in the Quix Portal
Quix__Sdk__Token=

# OpenF1 importer configuration
OPENF1_BASE_URL=https://api.openf1.org/v1
OPENF1_YEAR=2023
OPENF1_MEETING=Monza
OPENF1_SESSION_NAME=Race
OPENF1_SESSION_KEY=
INCLUDE_CAR_DATA=true

# Output topic names (auto-injected in Quix Cloud)
output_sessions=openf1-sessions
output_drivers=openf1-drivers
output_laps=openf1-laps
output_stints=openf1-stints
output_pit=openf1-pit
output_position=openf1-position
output_intervals=openf1-intervals
output_weather=openf1-weather
output_race_control=openf1-race-control
output_team_radio=openf1-team-radio
output_car_data=openf1-car-data
