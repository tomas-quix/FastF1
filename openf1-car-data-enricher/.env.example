# Quix SDK Token — find this in the Quix Portal under Settings > Tokens (SDK Tokens section)
Quix__Sdk__Token=

# Topic names (from your Quix environment)
DATA_TOPIC=openf1-car-data
CONFIG_TOPIC=config-ui
OUTPUT_TOPIC=openf1-car-data-enriched

# Kafka consumer group
CONSUMER_GROUP_NAME=openf1-car-data-enricher-v1

# JSON mapping of output field names to config field references (category.field_name)
LOOKUP_FIELDS_JSON={"driver_full_name":"drivers.full_name","year":"sessions.year","circuit":"sessions.circuit_short_name","session_type":"sessions.session_type","session_name":"sessions.session_name","meeting_name":"meetings.meeting_name"}
