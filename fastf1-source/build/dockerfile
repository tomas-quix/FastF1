FROM python:3.11-slim-bullseye

ENV DEBIAN_FRONTEND="noninteractive"
ENV PYTHONUNBUFFERED=1
ENV PYTHONIOENCODING=UTF-8

# Install system dependencies needed by numpy/pandas/matplotlib (used by fastf1)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgomp1 \
    gcc \
    g++ \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=git /project .
RUN find . | grep requirements.txt | xargs -I '{}' python3 -m pip install -r '{}'

# Pre-download FastF1 session data into the image so the container needs no
# network access to livetiming endpoints (blocked from Quix Cloud IPs at runtime).
# If livetiming is unreachable at build time this step will fail, which is
# intentional — the image must not be built without real data.
RUN python3 -c "\
import os, fastf1; \
os.makedirs('/app/ff1_cache', exist_ok=True); \
fastf1.Cache.enable_cache('/app/ff1_cache'); \
session = fastf1.get_session(2023, 1, 'R'); \
session.load(telemetry=True, laps=True, weather=False, messages=False); \
lap_count = len(session.laps); \
assert lap_count > 0, 'FastF1 session laps empty — livetiming unreachable at build time'; \
print('Cache populated:', lap_count, 'laps loaded for', session.event[\"EventName\"]); \
"

ENTRYPOINT ["python3", "fastf1-source/main.py"]
