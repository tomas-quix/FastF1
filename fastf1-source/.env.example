# Quix SDK token for the target environment (find in Settings > Tokens in the Quix Portal)
Quix__Sdk__Token=

# Output topic names
output_telemetry=f1-car-telemetry
output_lap_data=f1-lap-data
output_position=f1-position-data

# Mode: historical or live
MODE=historical

# Year to load (e.g. 2024)
YEAR=2024

# Round filter (e.g. Monaco, Bahrain, or round number like 5). Leave empty for all.
ROUND=

# Session filter (e.g. Race, Q, FP1, FP2, FP3). Leave empty for all.
SESSION=Race

# Playback speed: 0 = max speed, 1.0 = real-time, 2.0 = 2x speed
PLAYBACK_SPEED=0
