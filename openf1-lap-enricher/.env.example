# Quix SDK Token - find this in the Quix Portal under Settings > Tokens (SDK Tokens section)
Quix__Sdk__Token=

# Topic names (from your Quix environment)
DATA_TOPIC=openf1-car-data-enriched
LAP_TOPIC=openf1-laps
OUTPUT_TOPIC=openf1-car-data-lap-enriched

# Optional: Kafka consumer group name
CONSUMER_GROUP=openf1-lap-enricher-v1
